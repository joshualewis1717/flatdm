generator client {
  provider        = "prisma-client-js"
  // only if your Prisma version/docs still require it
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  firstName     String
  lastName      String
  email         String    @unique
  emailVerified Boolean   @default(false)
  passwordHash  String
  role          Role
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile    Profile?
  magicLinks MagicLink[]

  // Listings (landlord)
  properties Property[]
  listings   PropertyListing[] @relation("LandlordListings")

  // Applications (consultant)
  applications PropertyApplication[]

  // Messaging
  sentMessages   Message[]      @relation("SentMessages")
  conversationsA Conversation[] @relation("ConversationUserA")
  conversationsB Conversation[] @relation("ConversationUserB")

  messageRequestsSent     MessageRequest[] @relation("MessageRequestSender")
  messageRequestsReceived MessageRequest[] @relation("MessageRequestReceiver")

  // Reviews
  reviewsWritten  Review[] @relation("ReviewsWritten")
  reviewsReceived Review[] @relation("ReviewsReceived")

  // Reports
  reportsMade    Report[] @relation("ReportsMade")
  reportsAgainst Report[] @relation("ReportsAgainst")

  offences  OffenceRecord[]
  occupants Occupant[] // array to store rental history if need be
}

model Profile {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  phone      String?
  bio        String?
  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model MagicLink {
  id        Int           @id @default(autoincrement())
  tokenHash String        @unique
  type      MagicLinkType
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([email, type])
  @@index([expiresAt])
}

// Demo note: we know storing image blobs directly in the database is usually bad practice for a real production setup.
// This is only for demonstration purposes, in a real environment we would move image storage to object storage/CDN and keep only references here.
model ListingImage {
  id        Int     @id @default(autoincrement())
  fileName  String?
  mimeType  String
  sizeBytes Int
  data      Bytes

  isThumbnail Boolean @default(false)

  listingId Int
  listing   PropertyListing @relation(fields: [listingId], references: [id])

  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt
}

// we are modelling it as the entire building
model Property {
  id         Int    @id @default(autoincrement())
  title      String
  streetName String @map("address") // i couldn't be arsed to re-add the 3 rows so just mapped it to the old name - ill fix in SQL later
  city       String
  postcode   String

  lat    Float
  lng    Float
  coords Unsupported("geometry(Point, 4326)")? // PostGIS

  landlordId Int
  landlord   User @relation(fields: [landlordId], references: [id])

  // shared building-level data
  amenities Amenity[]

  // flats inside the building
  listings PropertyListing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([streetName, city, postcode, landlordId])
}

// we are modelling it as a single flat
model PropertyListing {
  id Int @id @default(autoincrement())

  // optional flat number inside each building
  flatNumber  String?
  description String

  rent Int

  lat    Float
  lng    Float
  coords Unsupported("geometry(Point, 4326)")? // PostGIS

  // rental rules
  maxOccupants Int // e.g. withRoomates boolean or whatnot is derived from this
  minStay      Int

  rooms          Int
  bedrooms       Int
  bathrooms      Int
  area           Int
  furnished_type FurnishedType

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])

  landlordId Int
  landlord   User @relation("LandlordListings", fields: [landlordId], references: [id])

  occupants    Occupant[]
  applications PropertyApplication[]
  reviews      Review[]
  reports      Report[]

  images ListingImage[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([flatNumber, propertyId])
}

model PropertyApplication {
  id Int @id @default(autoincrement())

  email   String?
  phone   String?
  message String?

  moveInDate  DateTime
  moveOutDate DateTime?

  status     ApplicationStatus
  expiryDate DateTime?
  updatedAt  DateTime          @default(now()) @updatedAt

  userId    Int
  listingId Int

  user    User            @relation(fields: [userId], references: [id])
  listing PropertyListing @relation(fields: [listingId], references: [id])

  createdAt DateTime @default(now())
}

model Occupant {
  id Int @id @default(autoincrement())

  userId    Int
  listingId Int

  moveIn  DateTime
  moveOut DateTime?

  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt

  user    User            @relation(fields: [userId], references: [id])
  listing PropertyListing @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId, moveIn]) // prevents duplicate occupancy
}

model Conversation {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt

  userAId Int
  userBId Int

  userA User @relation("ConversationUserA", fields: [userAId], references: [id])
  userB User @relation("ConversationUserB", fields: [userBId], references: [id])

  isDeletedA Boolean   @default(false)
  isDeletedB Boolean   @default(false)
  deletedAtA DateTime?
  deletedAtB DateTime?

  messages Message[]
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt

  senderId       Int
  conversationId Int

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  sender       User         @relation("SentMessages", fields: [senderId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])
}

model MessageRequest {
  id         Int           @id @default(autoincrement())
  status     RequestStatus
  createdAt  DateTime      @default(now())
  modifiedAt DateTime      @default(now()) @updatedAt

  senderId   Int
  receiverId Int

  sender   User @relation("MessageRequestSender", fields: [senderId], references: [id])
  receiver User @relation("MessageRequestReceiver", fields: [receiverId], references: [id])
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt

  authorId     Int
  targetUserId Int?
  listingId    Int?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  author     User             @relation("ReviewsWritten", fields: [authorId], references: [id])
  targetUser User?            @relation("ReviewsReceived", fields: [targetUserId], references: [id])
  listing    PropertyListing? @relation(fields: [listingId], references: [id])
}

model Report {
  id                  Int              @id @default(autoincrement())
  reason              String
  description         String?
  status              ReportStatus
  assignedModeratorId Int?
  severity            OffenceSeverity? @default(UNRANKED)
  category            ReportCategory?

  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt

  reporterId     Int
  targetUserId   Int
  listingId      Int?
  conversationId Int?
  reviewId       Int?

  reporter   User             @relation("ReportsMade", fields: [reporterId], references: [id])
  targetUser User?            @relation("ReportsAgainst", fields: [targetUserId], references: [id])
  listing    PropertyListing? @relation(fields: [listingId], references: [id])
}

model OffenceRecord {
  id         Int      @id @default(autoincrement())
  reason     String
  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

model Amenity {
  id         Int         @id @default(autoincrement())
  name       String
  type       AmenityType
  distance   Float
  modifiedAt DateTime    @default(now()) @updatedAt

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])
}

enum AmenityType {
  HEALTHCARE
  TRANSPORT
  RECREATIONAL
  OTHER
}

enum Role {
  CONSULTANT
  LANDLORD
  MODERATOR
}

enum ApplicationStatus {
  PENDING
  APPROVED
  CONFIRMED
  REJECTED
  WITHDRAWN
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MagicLinkType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
}

enum ListingType {
  ENTIRE_PROPERTY
  ROOM
}

enum OffenceSeverity {
  LOW
  MEDIUM
  HIGH
  UNRANKED
}

enum ReportCategory {
  INAPPROPRIATE_CONTENT
  FRAUD
  HARASSMENT
  FAKE_INFORMATION
  IMPERSONATION
  OTHER
}

enum FurnishedType {
  UNFURNISHED
  PART_FURNISHED
  FULLY_FURNISHED
}
